# 河北工业大学本科报考咨询环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ── 应用 ──────────────────────────────────────────────────────────────────────
APP_NAME=HebutAdmissions
APP_ENV=production
LOG_LEVEL=INFO

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 可选：覆盖为兼容 Anthropic 协议的第三方 API（如 DeepSeek）
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 可选：覆盖模型名称（默认 claude-3-5-sonnet-20241022）
# 使用 DeepSeek 时设为 deepseek-chat
# ANTHROPIC_MODEL=deepseek-chat

# DeepSeek Anthropic 兼容接口默认为思考模式；咨询、路由和 JSON 提取建议关闭
DEEPSEEK_THINKING_MODE=disabled

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=echomind123

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIRECTORY=./data/chroma
KNOWLEDGE_COLLECTION=hello_hebut
# 启动时自动扫描并增量导入 txt/md/json；留空可关闭
KNOWLEDGE_SEED_DIR=./data/demo_docs
# LLM 重排相关性采用 0-10 分，低于该值的知识片段不会进入回答上下文
RAG_RERANK_MIN_SCORE=5.0

# 河北、天津2023—2025年分专业最低分和最低位次长表
ADMISSION_DATA_PATH=./data/hebut_admission.csv

# ── 监控 ──────────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9091
ANOMALY_DETECTION_THRESHOLD=2.0

# ── 评测 ──────────────────────────────────────────────────────────────────────
EVAL_BASELINE_PATH=./data/eval/baseline.json
# 可选：使用与回答模型不同的 Judge，未配置时沿用 ANTHROPIC_MODEL
# EVAL_JUDGE_MODEL=your_judge_model

# ── Skills ───────────────────────────────────────────────────────────────────
# 默认读取项目内 ./skills，支持运行时通过 POST /skills/reload 热加载
ECHOMIND_SKILLS_DIR=./skills
ECHOMIND_SKILLS_MAX_PROMPT_CHARS=5000

# ── 安全 ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production
JWT_SECRET_KEY=change_this_in_production
# 配置后，知识写入、Skills 重载和评测接口要求 X-Admin-Token 请求头
ADMIN_API_TOKEN=
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── 功能开关 ──────────────────────────────────────────────────────────────────
ENABLE_SWAGGER_UI=true
ENABLE_MONITORING=true
ENABLE_EVALUATION=true
